# Copia este archivo como .env y rellena los valores

# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_KEY=tu-anon-key

# Cloudflare Worker (proxy AI)
# Dev:  http://localhost:8787
# Prod: https://approcesos-ai-proxy.tu-cuenta.workers.dev
VITE_AI_PROXY_URL=http://localhost:8787

# N8N Webhook (notificaciones)
VITE_N8N_WEBHOOK=https://tu-n8n.dominio.com/webhook/diagnostico

# Versión política privacidad
VITE_PRIVACY_VER=1.1
